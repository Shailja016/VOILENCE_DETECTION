PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/surveillance
CLIENT_ORIGIN=http://localhost:5173

# LLM: auto | openai | ollama | mock
# auto: OpenAI if OPENAI_API_KEY set, else Ollama, else built-in mock
LLM_PROVIDER=auto

# Strict mode: when true, /api/analyze-incident fails instead of falling back to mock.
LLM_STRICT=false

# Retry: number of additional attempts after the first call (repair prompt enabled on retries).
LLM_RETRY_COUNT=2

# Efficiency tuning (applies across providers where supported)
LLM_TEMPERATURE=0.15
LLM_MAX_OUTPUT_TOKENS=600

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local LLM (Ollama): ollama pull llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=120000
OLLAMA_NUM_PREDICT=420
